---
import type { Contact } from '@/lib/cv/schema';

interface Props {
  contact: Contact;
  /** When set, render a "Download PDF" button pointing here. */
  pdfHref?: string;
}

const { contact, pdfHref } = Astro.props;

// Inner markup for small lucide-style icons, keyed by name. Rendered inside a
// shared <svg> wrapper below via set:html.
const ICONS: Record<string, string> = {
  phone:
    '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>',
  mail: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  github:
    '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  linkedin:
    '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>',
  globe:
    '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>',
  download:
    '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>',
};

function linkIcon(url: string): string {
  const u = url.toLowerCase();
  if (u.includes('github')) return 'github';
  if (u.includes('linkedin')) return 'linkedin';
  return 'globe';
}

// Flatten phone/email/links into one uniform list of contact links.
type Entry = { href: string; label: string; icon: string };
const entries: Entry[] = [];
if (contact.phone) {
  entries.push({ href: `tel:${contact.phone.replace(/\s+/g, '')}`, label: contact.phone, icon: 'phone' });
}
entries.push({ href: `mailto:${contact.email}`, label: contact.email, icon: 'mail' });
for (const link of contact.links) {
  entries.push({ href: link.url, label: link.label, icon: linkIcon(link.url) });
}
---

<header class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
  <div class="min-w-0">
    <h1 class="text-3xl font-bold sm:text-4xl">{contact.name}</h1>

    <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-muted-foreground">
      {
        entries.map((entry) => (
          <a
            href={entry.href}
            class="inline-flex items-center gap-1.5 break-words transition-colors hover:text-foreground"
          >
            <svg
              class="h-4 w-4 shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={ICONS[entry.icon]}
            />
            <span>{entry.label}</span>
          </a>
        ))
      }
    </div>
  </div>

  {
    pdfHref && (
      <a
        href={pdfHref}
        download
        class="inline-flex w-full shrink-0 items-center justify-center gap-2 rounded-md border border-border px-3 py-2 text-sm font-medium transition-colors hover:bg-accent sm:w-auto"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          set:html={ICONS.download}
        />
        <span>Download PDF</span>
      </a>
    )
  }
</header>
