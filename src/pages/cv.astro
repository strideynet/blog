---
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { loadCv } from '@/lib/cv/load';
import CvHeader from '@/components/cv/CvHeader.astro';
import CvSection from '@/components/cv/CvSection.astro';
import ExperienceItem from '@/components/cv/ExperienceItem.astro';
import SkillGroups from '@/components/cv/SkillGroups.astro';

// Single source of truth: the same YAML that generates the LaTeX/PDF. Invalid
// data throws here and fails the build (see loadCv).
const cv = loadCv();

// Only offer the PDF download if the generated PDF has been copied into public/
// (npm run cv:pdf does this), so the link is never dead.
const pdfHref = existsSync(resolve(process.cwd(), 'public/noah-stride-cv.pdf'))
  ? '/noah-stride-cv.pdf'
  : undefined;

// Blank line starts a new paragraph (same rule as latex.ts). Summaries are YAML
// literal (|) blocks, so a blank line is preserved as \n\n.
const summaryParas = cv.summary
  ? cv.summary
      .trim()
      .split(/\n\s*\n/)
      .map((para) => para.replace(/\s+/g, ' ').trim())
  : [];
---

<BaseLayout title="CV" description={summaryParas[0]}>
  <article class="mx-auto max-w-4xl">
    <CvHeader contact={cv.contact} pdfHref={pdfHref} />

    {
      summaryParas.length > 0 && (
        <CvSection title="Summary">
          <div class="space-y-3">
            {summaryParas.map((para) => (
              <p class="text-sm sm:text-base">{para}</p>
            ))}
          </div>
        </CvSection>
      )
    }

    {
      cv.experiences.length > 0 && (
        <CvSection title="Experience">
          {cv.experiences.map((exp) => (
            <ExperienceItem experience={exp} />
          ))}
        </CvSection>
      )
    }

    {
      cv.skills.length > 0 && (
        <CvSection title="Skills">
          <SkillGroups skills={cv.skills} />
        </CvSection>
      )
    }
  </article>
</BaseLayout>
